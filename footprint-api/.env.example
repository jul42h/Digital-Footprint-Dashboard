DYNAMODB_TABLE_NAME=enriched-database
AWS_REGION=us-west-2
S3_BUCKET_NAME=01-su2026-cybersecurity-internship
NVD_API_KEY= a5d9d109-1a23-43cf-a03d-491c5c25bbf4

# DynamoDB table holding the CVE IDs you want checked against NVD
DYNAMODB_TABLE_NAME=enriched-database
# Attribute name in that table that stores the CVE ID (e.g. "CVE-2021-44228")
DYNAMODB_CVE_ID_ATTRIBUTE=cve_id



# Optional: override frontend build path (default: ../frontend/dist)
# FRONTEND_DIST=../frontend/dist

# Proxy to Vite dev server for live UI (run `npm run dev` in another terminal)
# FRONTEND_DEV_URL=http://127.0.0.1:5173

# Force a fresh npm run build on every API start
FRONTEND_ALWAYS_REBUILD=1
