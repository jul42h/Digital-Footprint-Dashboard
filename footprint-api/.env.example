DYNAMODB_TABLE_NAME=enriched-database
AWS_REGION=us-west-2
S3_BUCKET_NAME=01-su2026-cybersecurity-internship
NVD_API_KEY=

# DynamoDB table holding the CVE IDs you want checked against NVD
# Attribute name in that table that stores the CVE ID (e.g. "CVE-2021-44228")
DYNAMODB_CVE_ID_ATTRIBUTE=cve_id

# CVE AI Analysis (invokes AI Risk Analyzer Lambda — no direct Bedrock from API)
# CVE_ANALYZER_LAMBDA_NAME=ai-risk-analyzer
# CVE_ANALYZER_LAMBDA_REGION=us-west-2
# CVE_ANALYZER_LAMBDA_TIMEOUT_SECONDS=60
# CVE_ANALYZER_MAX_CONCURRENT_REQUESTS=2
# CVE_ANALYZER_MAX_ADMITTED_REQUESTS=6
# CVE_ANALYZER_RETRY_AFTER_SECONDS=10

# Optional: override frontend build path (default: ../frontend/dist)
# FRONTEND_DIST=../frontend/dist

# Proxy to Vite dev server for live UI (run `npm run dev` in another terminal)
# FRONTEND_DEV_URL=http://127.0.0.1:5173

# Force a fresh npm run build on every API start
FRONTEND_ALWAYS_REBUILD=1

# Subnet-level IP masking for the "viewer" role (see ip_masking.py). Salts
# the per-host opaque token so it can't be reversed without this secret —
# only required once a viewer-role user exists; the API raises at the
# first viewer dashboard request if unset, mirroring AUTH_JWT_SECRET.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# IP_MASK_SALT=
